{
  "name": "sinefineinfinitum/ponymator",
  "description": "Ponymator - generate docs for php project",
  "license": ["MIT"],
  "keywords": ["docs", "analysis"],
  "bin": [
    "ponymator",
    "ponymator.phar"
  ],
  "require": {
    "php": "^8.0",
    "nikic/php-parser": "^5.7",
    "sinefineinfinitum/parser-ps": "0.1.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "phpstan/phpstan": "^2.2",
    "squizlabs/php_codesniffer": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "SineFine\\Ponymator\\": "src/"
    }
  },
  "repositories": [{
    "name": "parser-ps",
    "type": "vcs",
    "url": "https://github.com/sinefineinfinitum/parser-ps"
  }]
}
