{
    "name": "sinefineinfinitum/ponymator",
    "description": "A CLI-first PHP documentation generator that produces deterministic Markdown and PSV1 documentation using AST analysis. Optimized for AI agents context with significant token savings.",
    "type": "library",
    "license": ["MIT"],
    "keywords": ["docs", "analysis", "php", "ast", "markdown", "psv1", "ai-context", "documentation-generator"],
    "bin": [
        "ponymator"
    ],
    "require": {
        "php": "^8.0",
        "nikic/php-parser": "^5.7",
        "sinefineinfinitum/parser-ps": "0.1.2",
      "ext-pdo": "*"
    },
    "autoload": {
        "psr-4": {
            "SineFine\\Ponymator\\": "src/",
            "SineFine\\Ponymator\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5.0",
        "phpstan/phpstan": "^2.2",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "repositories": [{
        "name": "parser-ps",
        "type": "vcs",
        "url": "https://github.com/sinefineinfinitum/parser-ps"
    }]
}
