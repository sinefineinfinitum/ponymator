{
    "name": "sinefineinfinitum/ponymator",
    "description": "Ponymator - generate docs for php project",
    "license": ["MIT"],
    "keywords": ["docs", "analysis"],
    "bin": [
        "ponymator",
        "ponymator.phar"
    ],
    "require": {
        "php": "^8.0",
        "nikic/php-parser": "^5.7"
    },
    "autoload": {
        "psr-4": {
            "SineFine\\Ponymator\\": "src/",
            "SineFine\\Ponymator\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5.0",
        "phpstan/phpstan": "^2.2",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "config": {
        "audit": {
            "ignore": ["PKSA-z3gr-8qht-p93v"]
        }
    }
}
