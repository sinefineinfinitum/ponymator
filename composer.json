{
    "name": "sinefineinfinitum/mnemosyne",
    "description": "Ponymator - generate docs for php project",
    "license": ["MIT"],
    "keywords": ["docs", "analysis"],
    "bin": [
        "ponymator"
    ],
    "require": {
        "php": "^8.0",
        "nikic/php-parser": "^5.7",
        "sinefineinfinitum/parser-ps": "0.1.2",
      "ext-pdo": "*"
    },
    "autoload": {
        "psr-4": {
            "SineFine\\Mnemosyne\\": "src/",
            "SineFine\\Mnemosyne\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5.0",
        "phpstan/phpstan": "^2.2",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "repositories": [{
        "name": "parser-ps",
        "type": "vcs",
        "url": "https://github.com/sinefineinfinitum/parser-ps"
    }]
}
